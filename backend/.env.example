# Database Configuration
DATABASE_URL=postgresql://suitability_user:password@localhost:5432/suitability_db
POSTGRES_DB=suitability_db
POSTGRES_USER=suitability_user
POSTGRES_PASSWORD=password

# Environment
ENVIRONMENT=development
DEBUG=True

# Security (generate a real secret key for production)
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
