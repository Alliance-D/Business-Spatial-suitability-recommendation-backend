# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://suitability_user:your_strong_password@localhost:5432/suitability_db
POSTGRES_USER=suitability_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=suitability_db

# ─── Admin authentication ─────────────────────────────────────────────────────
ADMIN_USERNAME=admin

# Option A (production — recommended):
# Generate a bcrypt hash of your password with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# Then set ADMIN_PASSWORD_HASH to the output. Leave ADMIN_PASSWORD empty.
ADMIN_PASSWORD_HASH=

# Option B (development only — plain text, less secure):
# Only used if ADMIN_PASSWORD_HASH is not set.
ADMIN_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 bytes (64 hex characters).
SECRET_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For local development: http://localhost,http://localhost:5173
# For production: https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ─── HTTPS ───────────────────────────────────────────────────────────────────
# Set to true in production to enable Secure flag on cookies.
HTTPS_ENABLED=false

# ─── Frontend (Vite build-time) ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT_MS=12000
